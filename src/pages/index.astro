---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Programme">
  <section class="programme-section">
    <div class="programme-container">
      <img src="/images/programme/page-01.png" alt="Programme - Page 1" class="programme-image" loading="eager" />
      <img src="/images/programme/page-02-03.png" alt="Programme - Pages 2-3" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-04.png" alt="Programme - Page 4" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-05.png" alt="Programme - Page 5" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-06.png" alt="Programme - Page 6" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-07.png" alt="Programme - Page 7" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-08.png" alt="Programme - Page 8" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-09.png" alt="Programme - Page 9" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-10.png" alt="Programme - Page 10" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-11.png" alt="Programme - Page 11" class="programme-image" loading="lazy" />
      <img src="/images/programme/page-12.png" alt="Programme - Page 12" class="programme-image" loading="lazy" />
    </div>
  </section>
</Layout>

<style>
  .programme-section {
    background-color: var(--color-bg-alt);
    min-height: 100vh;
  }

  .programme-container {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .programme-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  @media (min-width: 768px) {
    .programme-container {
      padding: var(--spacing-xl) var(--spacing-lg);
      gap: var(--spacing-md);
    }

    .programme-image {
      border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }
  }
</style>
