---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quartier de la Forêt">
  <section class="quartier-section">
    <div class="quartier-container">
      <object
        data="/images/quartier/Quartier de la Forêt.pdf"
        type="application/pdf"
        class="quartier-pdf"
      >
        <p>Votre navigateur ne supporte pas l'affichage des PDF.
          <a href="/images/quartier/Quartier de la Forêt.pdf" download>Télécharger le PDF</a>
        </p>
      </object>
    </div>
  </section>
</Layout>

<style>
  .quartier-section {
    background-color: var(--color-bg-alt);
  }

  .quartier-container {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--spacing-md);
  }

  .quartier-pdf {
    width: 100%;
    height: 80vh;
    display: block;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    border: none;
  }

  @media (min-width: 768px) {
    .quartier-container {
      padding: var(--spacing-xl) var(--spacing-lg);
    }

    .quartier-pdf {
      height: 90vh;
      border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }
  }
</style>
